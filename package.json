{
  "name": "tokenq",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"tsx watch src/server.ts\"",
    "dev:web": "next dev",
    "dev:server": "tsx watch src/server.ts",
    "build:web": "next build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:server && npm run build:web",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.21.0",
    "mongoose": "^8.9.5",
    "next": "^16.2.9",
    "nodemailer": "^9.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "socket.io": "^4.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
